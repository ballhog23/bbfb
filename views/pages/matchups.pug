extends ../layouts/base

block content
    main
        header
            h1 Bleed Blue Fantasy Football
        section.matchups-container
            header
                h2 Season #{currentLeagueSeason} - Week #{currentWeek}
                .select-wrapper
                    include ../partials/league-select.pug
                    include ../partials/week-select.pug
            section#matchups-wrapper
                include ../partials/matchups-section.pug
        section.standings-container
            include ../partials/standings-section.pug
