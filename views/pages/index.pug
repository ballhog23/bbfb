extends ../layouts/base
block head
block content
    main
        header.page-header.container
            h1 Bleed Blue Fantasy Football
        if leagueState.leg > 17
            section.previous-season-outcome.container
                .winner
                    img(
                        src= 'assets/mascot.webp',
                        loading= 'eager'
                        decoding= 'sync'
                    )
                    .card-body
                        h2 #{leagueState.season} Season Champ
                        p #{winner.teamName}
                .loser
                    img(
                        src= 'assets/sad-mascot.webp',
                        loading= 'eager'
                        decoding= 'sync'
                    )
                    .card-body
                        h2 #{leagueState.season} Season Sacko
                        p #{loser.teamName}
        section.matchups-cta.container
            h2 Check Out League Matchups
            a.btn(href="/matchups") League Matchups
