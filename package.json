  "scripts": {
    "build:server": "tsc -p tsconfig.json",
    "build:client": "tsc -p tsconfig.web.json",
    "build": "npm run build:server && npm run build:client",
    "dev": "npm run build && tsc -p tsconfig.json --watch & tsc -p tsconfig.web.json --watch & node --watch dist/server.js",
    "start": "node dist/server.js",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "push": "drizzle-kit push",
    "test": "NODE_OPTIONS='--localstorage-file=/home/caleb/.vitest/vitest.localstorage' vitest --run",
    "tee": "npm run dev | tee info.log"
  },
